profile global c;

check-function malloc;

check-function fstat {
  header sys/stat.h;
}

# windows has 'max' defined, unix-like systems have 'MAX' in sys/param.h
# these are both macros
if (MKC_SYS_WINDOWS) {
  check-function max {
    name _function_max;
  }
} else {
  check-function MAX {
    header sys/param.h;
    name _function_max;
  }
}

check-function sqrt {
  header math.h;
  link-flags '-lm';
}

if (${_function_malloc} == 1) {
  print '  ok';
} else {
  print '  fail malloc';
}

if (${_function_fstat} == 1) {
  print '  ok';
} else {
  print '  fail fstat';
}

if (${_function_max} == 1) {
  print '  ok';
} else {
  print '  fail max';
}

if (${_function_sqrt} == 1) {
  print '  ok';
} else {
  print '  fail sqrt';
}

