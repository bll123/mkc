# basic tests putting variables into different profiles
profile global {
  set d 'g-general';
}
profile global {
  compiler c;
  set c 'g-c';
}
profile release {
  compiler c;
  set k 'r-c';
}
profile global {
  compiler c++;
  set b 'g-c++';
}
profile global {
  set f 'g-general';
}
profile global {
  compiler c;
  set e 'g-c';
}
profile global {
  compiler c++;
  set f 'g-c++';
}
profile release {
  compiler c++;
  set h 'r-c++';
}
profile debug {
  compiler c++;
  set i 'd-c++';
}

mkcdebug printprof;
mkcdebug printvar test;
mkcdebug printvar release;
mkcdebug printvar debug;
