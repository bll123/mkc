# basic tests putting variables into different profiles
profile development {
  compiler c;
  set a 'd-c';
}
profile development {
  compiler c++;
  set b 'd-c++';
}
profile release {
  compiler c;
  set c 'r-c';
}
profile debug {
  compiler c++;
  set d 'dbg-c++';
}

mkcdebug printprof;
mkcdebug printvar test;
mkcdebug printvar release;
mkcdebug printvar debug;
