# basic tests putting variables into different profiles
profile global {
  set d "g-general";
}
profile global c {
  set c "g-c";
}
profile release c {
  set i "r-c";
}
profile global c++ {
  set b "g-c++";
}
profile global {
  set f "g-general";
}
profile global c {
  set e "g-c";
}
profile global c++ {
  set f "g-c++";
}
profile release c++ {
  set h "r-c++";
}
profile debug c++ {
  set i "d-c++";
}

mkcdebug printprof;
mkcdebug printvar test;
mkcdebug printvar release;
mkcdebug printvar debug;
