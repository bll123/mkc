check_package unknown;
check_package zlib;

if (${_package_unknown} == 0) {
  print '  ok u';
} else {
  print '  fail u';
}
if (! is_defined (unknown_CFLAGS)) {
  print '  ok u';
} else {
  print '  fail u';
}
if (! is_defined (unknown_LIBS)) {
  print '  ok u';
} else {
  print '  fail u';
}

if (${_package_zlib} == 1) {
  print '  ok z';
} else {
  print '  fail z';
}

# zlib_CFLAGS [ ]
# zlib_LIBS [ -lz ]
if (is_list (zlib_CFLAGS)) {
  print '  ok z';
} else {
  print '  fail z';
}
if (is_list (zlib_LIBS)) {
  print '  ok z';
} else {
  print '  fail z';
}
