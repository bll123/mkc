# Copyright 2026 Brad Lanam Pleasant Hill CA

project {
  name mkctest;
}

# these go into the current profile
check_function fprintf;
check_function malloc;

check_function fstat {
  header sys/stat.h;
}
check_function sqrt {
  header math.h;
  link_flags '-lm';
}
check_function other;

mark _function_malloc disable-output;

profile internal {
  mark MKC_SYS_UNKNOWN enable-output;
}

configure {
  method auto;
  define_zero;
  output 'tests/tmp/305-configure-mark.h';
}
