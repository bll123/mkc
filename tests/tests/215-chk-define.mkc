# windows has '__max' defined, unix-like systems have 'MAX' in sys/param.h
# these are both macros
if (${MKC_SYS_WINDOWS}) {
  check_define __max {
    name _def_max;
  }
} else {
  check_define MAX {
    header sys/param.h;
    name _def_max;
  }
}

check_define EPERM {
  header errno.h;
  success {
    print '  ok a';
  }
  failure {
    print '  fail a';
  }
}

check_define UNKNOWN {
  success {
    print '  fail b';
  }
  failure {
    print '  ok b';
  }
}

check_define ABC {
  compiler_flags '-DABC="hello world"';
}

if (${_def_max} == 1) {
  print '  ok max';
} else {
  print '  fail max';
}

if (${_define_EPERM} == 1) {
  print '  ok EPERM';
} else {
  print '  fail eperm';
}

if (${_define_ABC} == 1) {
  print '  ok ABC';
} else {
  print '  fail ABC';
}
