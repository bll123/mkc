check_package unknown {
  success {
    print '  fail a';
  }
  failure {
    print '  ok a';
  }
}
check_package zlib;
check_package zlib {
  name z;
  success {
    print '  ok b';
  }
  failure {
    print '  fail b';
  }
}

if (${_package_unknown} == 0) {
  print '  ok u';
} else {
  print '  fail u';
}
if (! is_defined (unknown_CFLAGS)) {
  print '  ok u';
} else {
  print '  fail u';
}
if (! is_defined (unknown_LIBS)) {
  print '  ok u';
} else {
  print '  fail u';
}

if (${_package_zlib} == 1) {
  print '  ok zlib';
} else {
  print '  fail zlib';
}

set a ${zlib_CFLAGS};
set b ${zlib_LIBS};
# zlib_CFLAGS [ ]
# zlib_LIBS [ -lz ]
if (is_list (a)) {
  print '  ok zlib';
} else {
  print '  fail zlib';
}
if (is_list (b)) {
  print '  ok zlib';
} else {
  print '  fail zlib';
}

if (${_package_z} == 1) {
  print '  ok z';
} else {
  print '  fail z';
}

set a ${z_CFLAGS};
set b ${z_LIBS};
# z_CFLAGS [ ]
# z_LIBS [ -lz ]
if (is_list (a)) {
  print '  ok z';
} else {
  print '  fail z';
}
if (is_list (b)) {
  print '  ok z';
} else {
  print '  fail z';
}
