# profile hierarchy
# only development/internal at this testing level

project {
  name mkctest;
  compiler c;
}

set d 4;
set c 3;

profile development {
  set f 6;
  set e 5;
}
profile development {
  compiler c;
  set h 8;
  set g 7;
}
profile development {
  compiler c++;
  set m 13;
  set l 12;
}
profile internal {
  set i 9;
}

if (${c} == 3) {
  # development c
  print '  ok 3';
}
if (${d} == 4) {
  # development c
  print '  ok 4';
}
if (${e} == 5) {
  # development c
  print '  ok 5';
}
if (${f} == 6) {
  # development c
  print '  ok 6';
}
if (${g} == 7) {
  # development c
  print '  ok 7';
}
if (${h} == 8) {
  # development c
  print '  ok 8';
}
if (${i} == 9) {
  # internal
  print '  ok 9';
}
if (${l} == 12) {
  # development c++
  # will not print, as the compiler is set to 'c'
  print '  ng 12';
}
if (${m} == 13) {
  # development c++
  # will not print, as the compiler is set to 'c'
  print '  ng 13';
}

mkcdebug printvar test;
