# profile hierarchy
# only release/global/internal at this testing level
profile global {
  set b 2;
  set a 1;
}
profile global c {
  set d 4;
  set c 3;
}
profile release {
  set f 6;
  set e 5;
}
profile release c {
  set h 8;
  set g 7;
}
profile internal {
  set i 9;
}

profile release c;

if (${a} == 1) {
  print '  ok 1';
}
if (${b} == 2) {
  print '  ok 2';
}
if (${c} == 3) {
  print '  ok 3';
}
if (${d} == 4) {
  print '  ok 4';
}
if (${e} == 5) {
  print '  ok 5';
}
if (${f} == 6) {
  print '  ok 6';
}
if (${g} == 7) {
  print '  ok 7';
}
if (${h} == 8) {
  print '  ok 8';
}
if (${i} == 9) {
  print '  ok 9';
}

mkcdebug printvar test;
mkcdebug printvar release;
