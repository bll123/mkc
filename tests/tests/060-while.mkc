# ordinary while loop
set count 0;
while (${count} < 5) {
  print "  ok ${count}";
  set count ${count} + 1;
}
print ' while fin';

# continue statement
set count 0;
while (${count} < 5) {
  if (${count} == 3) {
    set count ${count} + 1;
    continue;
  }
  print "  cont ${count}";
  set count ${count} + 1;
}
print ' while-continue fin';

# break statement
set count 0;
while (${count} < 5) {
  if (${count} == 3) {
    break;
  }
  print "  ok ${count}";
  set count ${count} + 1;
}
print ' while-break fin';

# nested while
set i 0;
while (${i} < 3) {
  print "  outer ${i}";
  set j 0;
  while (${j} < 2) {
    print "  inner ${j}";
    set j ${j} + 1;
  }
  set i ${i} + 1;
}
print ' nested fin';

# nested while with break in inner loop, break in outer loop
set i 0;
while (${i} < 5) {
  print "  outer ${i}";
  if (${i} == 3) {
    break;
  }
  set j 0;
  while (${j} < 3) {
    if (${j} == 1) {
      break;
    }
    print "  inner ${j}";
    set j ${j} + 1;
  }
  set i ${i} + 1;
}
print ' nested inner-break fin';

# buried break statement
set count 0;
while (${count} < 5) {
  if (${count} == 3) {
    if (${count} == 3) {
      if (${count} == 3) {
        break;
      }
      print '  fail';
    }
    print '  fail';
  }
  print "  ok ${count}";
  set count ${count} + 1;
}
print ' while-b-break fin';

# buried continue statement
set count 0;
while (${count} < 4) {
  if (${count} == 2) {
    if (${count} == 2) {
      if (${count} == 2) {
        set count ${count} + 1;
        continue;
      }
      print '  fail';
    }
    print '  fail';
  }
  print "  ok ${count}";
  set count ${count} + 1;
}
print ' while-b-cont fin';

