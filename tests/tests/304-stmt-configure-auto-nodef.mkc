project {
  name mkctest;
}

check_function malloc;
check_function fstat {
  header sys/stat.h;
}
check_function sqrt {
  header math.h;
  link_flags '-lm';
}
check_function other;

configure {
  method auto;
  output 'tests/tmp/304-stmt-configure-auto-nodef.h';
}
