
# windows has 'max' defined, unix-like systems have 'MAX' in sys/param.h
# these are both macros
if (MKC_SYS_WINDOWS) {
  check_define max {
    name _def_max;
  }
} else {
  check_define MAX {
    header sys/param.h;
    name _def_max;
  }
}

check_define EPERM {
  header errno.h;
}

if (${_def_max} == 1) {
  print '  ok';
} else {
  print '  fail max';
}

if (${_define_EPERM} == 1) {
  print '  ok';
} else {
  print '  fail eperm';
}
