# numeric comparisons

# ==
if (0 == 0) {
  print '  ok ==';
} else {
  print '  fail-a ==';
}

if (0 == 1) {
  print '  fail-b ==';
} else {
  print '  ok ==';
}

# !=
if (0 != 0) {
  print '  fail-a !=';
} else {
  print '  ok !=';
}

if (0 != 1) {
  print '  ok !=';
} else {
  print '  fail-b !=';
}

# <
if (0 < 0) {
  print '  fail-a <';
} else {
  print '  ok <';
}

if (0 < 1) {
  print '  ok <';
} else {
  print '  fail-b <';
}

if (1 < 0) {
  print '  fail-c <';
} else {
  print '  ok <';
}

# <=
if (0 <= 0) {
  print '  ok <=';
} else {
  print '  fail-a <=';
}

if (0 <= 1) {
  print '  ok <=';
} else {
  print '  fail-b <=';
}

if (1 <= 0) {
  print '  fail-c <=';
} else {
  print '  ok <=';
}

# >
if (0 > 0) {
  print '  fail-a >';
} else {
  print '  ok >';
}

if (0 > 1) {
  print '  fail-b >';
} else {
  print '  ok >';
}

if (1 > 0) {
  print '  ok >';
} else {
  print '  fail-c >';
}

# >=
if (0 >= 0) {
  print '  ok >=';
} else {
  print '  fail-a >=';
}

if (0 >= 1) {
  print '  fail-b >=';
} else {
  print '  ok >=';
}

if (1 >= 0) {
  print '  ok >=';
} else {
  print '  fail-c >=';
}

