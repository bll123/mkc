check_constant EPERM {
  header errno.h;
  success {
    print '  ok a';
  }
  failure {
    print '  fail a';
  }
}

check_constant O_RDONLY {
  header fcntl.h;
}

check_constant UNKNOWN {
  success {
    print '  fail b';
  }
  failure {
    print '  ok b';
  }
}

if (${_constant_EPERM} == 1) {
  print '  ok';
} else {
  print '  fail eperm';
}

if (${_constant_O_RDONLY} == 1) {
  print '  ok';
} else {
  print '  fail o_rdonly';
}
