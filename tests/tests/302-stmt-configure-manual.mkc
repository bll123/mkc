project {
  name mkctest;
}

check_function malloc;
check_function fstat {
  header sys/stat.h;
}
check_function sqrt {
  header math.h;
  link_flags '-lm';
}
check_function other;

configure {
  method manual;
  input 'tests/data/302-stmt-configure-manual.h';
  output 'tests/tmp/302-stmt-configure-manual.h';
}
