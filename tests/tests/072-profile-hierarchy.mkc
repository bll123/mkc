# profile hierarchy
# only default/internal at this testing level

project {
  name mkctest;
  compiler c;
}

set d 4;
set c 3;

profile default {
  compiler general;
  set f 6;
  set e 5;
}
profile default {
  compiler c;
  set h 8;
  set g 7;
}
profile debug {
  compiler c;
  set a 1;
  set b 2;
}
profile default {
  compiler c++;
  set m 13;
  set l 12;
}
profile internal {
  set i 9;
}

if (is_defined (a)) {
  print '  fail a';
  exit 1;
}
if (is_defined (b)) {
  print '  fail b';
  exit 1;
}
if (${c} == 3) {
  # default c
  print '  ok 3';
}
if (${d} == 4) {
  # default c
  print '  ok 4';
}
if (${e} == 5) {
  # default c
  print '  ok 5';
}
if (${f} == 6) {
  # default c
  print '  ok 6';
}
if (${g} == 7) {
  # default c
  print '  ok 7';
}
if (${h} == 8) {
  # default c
  print '  ok 8';
}
if (${i} == 9) {
  # internal general
  print '  ok 9';
}

if (is_defined (l)) {
  # default c++
  # will not print, as the compiler is set to 'c'
  print '  ng 12';
  exit 1;
}
if (is_defined (m)) {
  # default c++
  # will not print, as the compiler is set to 'c'
  print '  ng 13';
  exit 1;
}

mkcdebug printvar test;
