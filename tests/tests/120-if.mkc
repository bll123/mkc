
# make sure that the if statement condition can parse a variable

# make sure that the if statement only uses
# the original expression value and that statements within
# the block do not affect it.

print '  if,else/false (1)';
set a false;
if (${a}) {
  print '  fail-a';
} else {
  print '  ok';
}

print '  if,elseif,else/true,true (1)';
set a true;
if (${a}) {
  print '  ok';
  add_compile_flag '-DTEST';
} else if (true) {
  print '  fail-a';
  add_compile_flag '-DTEST';
} else {
  print '  fail-b';
}

print '  if,elseif,else/false,true (1)';
set a true;
if (false) {
  print '  fail-a';
  add_compile_flag '-DTEST';
} else if (${a}) {
  print '  ok';
  add_compile_flag '-DTEST';
} else {
  print '  fail-b';
}

print '  if,elseif,elseif,else/false,true,true (1)';
set a true;
if (false) {
  print '  fail-a';
  add_compile_flag '-DTEST';
} else if (${a}) {
  print '  ok';
  add_compile_flag '-DTEST';
} else if (${a}) {
  print '  fail-b';
  add_compile_flag '-DTEST';
} else {
  print '  fail-c';
}

print '  if,elseif{if,elseif,else},elseif,else/false,true,{true,true},true (2)';
set a true;
if (false) {
  print '  fail-a';
  add_compile_flag '-DTEST';
} else if (${a}) {
  print '  ok';
  add_compile_flag '-DTEST';
  if (${a}) {
    print '  ok';
    add_compile_flag '-DTEST';
  } else if (true) {
    print '  fail-b';
    add_compile_flag '-DTEST';
  } else {
    print '  fail-c';
  }
} else if (${a}) {
  print '  fail-d';
  add_compile_flag '-DTEST';
} else {
  print '  fail-e';
}
