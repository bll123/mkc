# basic tests putting variables into different profiles
profile default {
  compiler c;
  set a 'd-c';
}
profile default {
  compiler c++;
  set b 'd-c++';
}
profile release {
  compiler c;
  set c 'r-c';
}
profile debug {
  compiler c++;
  set d 'dbg-c++';
}

mkcdebug printprof;
mkcdebug printprofvar test;
mkcdebug printprofvar release;
mkcdebug printprofvar debug;
