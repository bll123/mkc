profile global c;
check_size int32_t {
  header stdint.h;
}
check_size int16_t {
  header stdint.h;
}
check_size int8_t {
  header stdint.h;
}
check_size int64_t {
  header stdint.h;
}
check_size 'struct stat' {
  header sys/stat.h;
}
check_size unknown_t;

if (${_size_int8_t} == 1) {
  print '  ok int8_t';
} else {
  print '  fail int8_t';
}
if (${_size_int16_t} == 2) {
  print '  ok int16_t';
} else {
  print '  fail int16_t';
}
if (${_size_int32_t} == 4) {
  print '  ok int32_t';
} else {
  print '  fail int32_t';
}
if (${_size_int64_t} == 8) {
  print '  ok int64_t';
} else {
  print '  fail int64_t';
}
if (${_size_struct_stat} > 8) {
  print '  ok struct stat';
} else {
  print '  fail struct stat';
}
if (${_size_unknown_t} == 0) {
  print '  ok unknown_t';
} else {
  print '  fail unknown_t';
}
