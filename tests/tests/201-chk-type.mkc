profile global c;
check-type something_t;
check-type int;
check-type 'struct stat' {
  header sys/stat.h;
  name _have_stat;
}

if (${_type_something_t} == 0) {
  print '  ok';
} else {
  print '  fail something';
}
if (${_type_int} == 1) {
  print '  ok';
} else {
  print '  fail int';
}
if (${_have_stat} == 1 && ${_type_struct_stat} == 0) {
  print '  ok';
} else {
  print '  fail struct stat';
}
