# Copyright 2026 Brad Lanam Pleasant Hill CA

project {
  name mkctest;
  compiler c;
}

profile global {
  compiler c;

  check_function malloc;
  check_function fstat {
    header sys/stat.h;
  }
  check_function sqrt {
    header math.h;
    link_flags '-lm';
  }
  check_function other;
}

configure {
  method auto;
  output 'tests/tmp/303-configure-auto-nodef.h';
}
