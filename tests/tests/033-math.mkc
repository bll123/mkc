# math operations

# +
if (1 + 1 == 2) {
  print '  ok +';
} else {
  print '  fail-a +';
}
if (1 + 2 == 3) {
  print '  ok +';
} else {
  print '  fail-a +';
}
if (0 + 2 == 2) {
  print '  ok +';
} else {
  print '  fail-a +';
}

# -
if (1 - 1 == 0) {
  print '  ok -';
} else {
  print '  fail-a -';
}
if (1 - 2 == -1) {
  print '  ok -';
} else {
  print '  fail-a -';
}
if (2 - 1 == 1) {
  print '  ok -';
} else {
  print '  fail-a -';
}

# *
if (1 * 2 == 2) {
  print '  ok *';
} else {
  print '  fail-a *';
}
if (2 * 2 == 4) {
  print '  ok *';
} else {
  print '  fail-a *';
}
if (0 * 2 == 0) {
  print '  ok *';
} else {
  print '  fail-a *';
}
if (2 * 0 == 0) {
  print '  ok *';
} else {
  print '  fail-a *';
}

# /  integer division
if (2 / 1 == 2) {
  print '  ok /';
} else {
  print '  fail-a /';
}
if (2 / 2 == 1) {
  print '  ok /';
} else {
  print '  fail-a /';
}
if (0 / 2 == 0) {
  print '  ok /';
} else {
  print '  fail-a /';
}
if (3 / 2 == 1) {
  print '  ok /';
} else {
  print '  fail-a /';
}
if (2 / 3 == 0) {
  print '  ok /';
} else {
  print '  fail-a /';
}

# %  integer modulo
if (2 % 1 == 0) {
  print '  ok %';
} else {
  print '  fail-a %';
}
if (2 % 2 == 0) {
  print '  ok %';
} else {
  print '  fail-a %';
}
if (0 % 2 == 0) {
  print '  ok %';
} else {
  print '  fail-a %';
}
if (3 % 1 == 0) {
  print '  ok %';
} else {
  print '  fail-a %';
}
if (3 % 2 == 1) {
  print '  ok %';
} else {
  print '  fail-a %';
}
if (3 % 3 == 0) {
  print '  ok %';
} else {
  print '  fail-a %';
}
if (2 % 3 == 2) {
  print '  ok %';
} else {
  print '  fail-a %';
}

if (1 + 2 * 3 == 7) {
  print '  ok prec';
} else {
  print '  fail-a prec';
}
if (1 + (2 * 3) == 7) {
  print '  ok paren';
} else {
  print '  fail-a paren';
}
if ((1 + 2) * 3 == 9) {
  print '  ok paren';
} else {
  print '  fail-b paren';
}
